{
	"name": "jimmy-importer",
	"version": "1.0.0",
	"description": "Import notes into Obsidian using the Jimmy converter.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"jimmy",
		"import",
		"markdown"
	],
	"license": "GPL-3.0",
	"devDependencies": {
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"typescript": "^5.8.3"
	}
}
